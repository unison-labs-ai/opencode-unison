{
  "name": "opencode-unison",
  "version": "1.0.0",
  "description": "OpenCode plugin for persistent memory using the Unison brain",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-unison": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && bun build ./src/cli.ts --outfile ./dist/cli.js --target node && tsc --emitDeclarationOnly",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "unison",
    "brain",
    "memory",
    "ai",
    "coding-agent"
  ],
  "author": "Unison Labs AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unison-labs-ai/opencode-unison"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.162",
    "@unisonlabs/sdk": "^1.3.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "event"
    ]
  },
  "files": [
    "dist"
  ]
}
