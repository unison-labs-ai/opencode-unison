# Unison brain API key — get one via `bunx opencode-unison@latest login`
# or from the Unison dashboard. Never commit a real key.
UNISON_TOKEN=usk_live_...

# Optional: override the brain API base URL (default: https://brain.unisonlabs.ai)
# UNISON_BASE_URL=https://brain.unisonlabs.ai

# Optional: override the Unison app URL used during browser login
# UNISON_APP_URL=https://app.unisonlabs.ai
